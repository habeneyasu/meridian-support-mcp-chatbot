# LLM provider: "gemini", "openai", or "anthropic"
LLM_PROVIDER=gemini

# API key for the chosen LLM provider
LLM_API_KEY=your-api-key-here

# Optional: override the default model for the chosen provider
# Defaults: gemini-1.5-flash / gpt-4o-mini / claude-haiku-...
LLM_MODEL=

# Optional: override the MCP server URL
# Default: https://order-mcp-74afyau24q-uc.a.run.app/mcp
MCP_SERVER_URL=
